# ─────────────────────────────────────────────
# SceptView Network Monitor — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Required ──────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://networkmonitor:CHANGE_ME@localhost:5432/networkmonitor

# Secret used to sign session cookies (use a long random string)
# Generate one with: openssl rand -hex 64
SESSION_SECRET=CHANGE_ME_use_openssl_rand_hex_64

# ── Server ────────────────────────────────────

NODE_ENV=production
PORT=5000

# ── Email / SMTP (optional — for alerts and password resets) ──

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=CHANGE_ME
SMTP_FROM_EMAIL=alerts@example.com

# ── Notes ─────────────────────────────────────
# Do NOT set REPL_ID — its absence is what activates local username/password auth.
# The first account created after startup becomes the admin.
